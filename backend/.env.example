# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cloud-code-runner

# JWT Secret Key (generate a strong random string)
# Can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_12345

# Node Environment
NODE_ENV=production

# Server Port
PORT=5000
